# Supabase 프로젝트 설정 (대시보드 > Settings > API에서 복사)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# 인트라넷 중계(프록시) 모드 — 캡처 기능에 필수
# 이 주소를 넣으면 개발 서버(및 Vercel 서버리스 프록시)가 같은 출처로 중계한다.
# 앱 접속 주소는 http://<PC IP>:5173/app/ (dev) 또는 https://<vercel>/app/ (프로덕션)
# Vercel에서는 대시보드 환경변수에 같은 이름으로 등록 (빌드+런타임 공용)
INTRANET_TARGET=https://success.jumpoline.com
