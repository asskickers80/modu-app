{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/app", "destination": "/index.html" },
    { "source": "/app/", "destination": "/index.html" },
    { "source": "/app/(.*)", "destination": "/$1" },
    { "source": "/((?!api/|assets/).*)", "destination": "/api/proxy?__path=/$1" }
  ]
}
