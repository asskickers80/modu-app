{
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/collect-market-news", "schedule": "0 20 * * *" },
    { "path": "/api/check-business-closure", "schedule": "0 20 * * 1" }
  ],
  "functions": {
    "api/collect-market-news.js": { "maxDuration": 60 },
    "api/check-business-closure.js": { "maxDuration": 60 }
  }
}
