{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"if (git status --porcelain) { [Console]::OutputEncoding=[Text.Encoding]::UTF8; Write-Output (-join([char]0x26A0,[char]0xFE0F,' ',[char]0xBBF8,[char]0xCEE4,[char]0xBC0B,' ',[char]0xBCC0,[char]0xACBD,' ',[char]0xC874,[char]0xC7AC)) }\""
          }
        ]
      }
    ]
  }
}
