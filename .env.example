VITE_GEMINI_API_KEY=your_gemini_api_key_here

# 공공데이터포털 (data.go.kr) API 키
# - "Decoding 키"를 사용하세요 (Encoding 키 사용 시 이중 인코딩 오류 발생)
# - 상업업무용 실거래가 API(RTMSDataSvcNrgTrade) 활용신청 필요
VITE_PUBLIC_DATA_KEY=your_public_data_key_here

# Supabase 프로젝트 (Settings → API 에서 확인)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# 네이버 검색 API — 배치 스크립트(collect-market-news.mjs)에서만 사용
# VITE_ 접두사 없음 — 브라우저에 노출되지 않음
# https://developers.naver.com/apps/ 에서 발급
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
